{
  "name": "Tags Input",
  "tag": "kb-tags-input",
  "category": "forms",
  "description": "An input for adding and removing text tags.",
  "importPaths": {
    "webComponent": "@wearesyntesa/karbit-ui/components/forms/kb-tags-input.define.js",
    "react": "@wearesyntesa/karbit-ui/react",
    "reactExport": "TagsInput"
  },
  "props": [
    {
      "name": "values",
      "attribute": "values",
      "type": "readonly string[]",
      "default": "[]",
      "reflect": false,
      "description": "Current tag values."
    },
    {
      "name": "placeholder",
      "attribute": "placeholder",
      "type": "string",
      "default": "undefined",
      "reflect": false,
      "description": "Placeholder text for the input."
    },
    {
      "name": "variant",
      "attribute": "variant",
      "type": "FormVariant",
      "default": "'outline'",
      "reflect": false,
      "description": "Visual variant."
    },
    {
      "name": "size",
      "attribute": "size",
      "type": "ComponentSize",
      "default": "'md'",
      "reflect": false,
      "description": "Display size."
    },
    {
      "name": "disabled",
      "attribute": "disabled",
      "type": "boolean",
      "default": "false",
      "reflect": false,
      "description": "Disable interaction."
    },
    {
      "name": "invalid",
      "attribute": "invalid",
      "type": "boolean",
      "default": "false",
      "reflect": false,
      "description": "Apply error styling."
    },
    {
      "name": "max",
      "attribute": "max",
      "type": "number",
      "default": "0",
      "reflect": false,
      "description": "Maximum number of tags allowed. 0 = unlimited."
    },
    {
      "name": "allowDuplicates",
      "attribute": "allow-duplicates",
      "type": "boolean",
      "default": "false",
      "reflect": false,
      "description": "Allow duplicate tag values."
    },
    {
      "name": "name",
      "attribute": "name",
      "type": "string",
      "default": "undefined",
      "reflect": false,
      "description": "Form field name."
    }
  ],
  "slots": [],
  "events": [
    {
      "name": "kb-change",
      "detail": "`KbChangeDetail` — discriminated union, narrow via `detail.source`",
      "description": "Fires on any value change. Detail: `{ source: 'tags-input', values: string[] }`."
    },
    {
      "name": "kb-tag-add",
      "detail": "`{ value: string }`",
      "description": "Fires when a tag is added. Detail: `{ value: string }`."
    },
    {
      "name": "kb-tag-remove",
      "detail": "`{ value: string, index: number }`",
      "description": "Fires when a tag is removed. Detail: `{ value: string, index: number }`."
    }
  ],
  "accessibility": {
    "roles": [],
    "ariaAttributes": [
      "aria-invalid"
    ],
    "keyboardKeys": [
      "Backspace",
      "Enter"
    ],
    "isOverlay": false
  },
  "relatedComponents": [
    "input",
    "tag",
    "tag-group"
  ]
}
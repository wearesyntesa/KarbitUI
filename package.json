{
  "name": "@wearesyntesa/karbit-ui",
  "version": "0.1.0",
  "description": "Brutalist design system built on Lit with Chakra UI-like API and Tailwind CSS",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/core/theme.d.ts",
      "import": "./dist/core/theme.js",
      "default": "./dist/core/theme.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./cx": {
      "types": "./dist/utils/cx.d.ts",
      "import": "./dist/utils/cx.js",
      "default": "./dist/utils/cx.js"
    },
    "./recipe": {
      "types": "./dist/core/recipe.d.ts",
      "import": "./dist/core/recipe.js",
      "default": "./dist/core/recipe.js"
    },
    "./types": {
      "types": "./dist/core/types.d.ts",
      "import": "./dist/core/types.js",
      "default": "./dist/core/types.js"
    },
    "./events": {
      "types": "./dist/core/events.d.ts",
      "import": "./dist/core/events.js",
      "default": "./dist/core/events.js"
    },
    "./tailwind.config": {
      "import": "./tailwind.config.ts",
      "default": "./tailwind.config.ts"
    },
    "./*": null
  },
  "sideEffects": [
    "./dist/components/**/*.js",
    "./dist/react/**/*.js"
  ],
  "customElements": "custom-elements.json",
  "files": [
    "dist",
    "tailwind.config.ts",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "cem": "cem analyze",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "knip": "knip",
    "spellcheck": "cspell \"src/**/*.ts\" \"stories/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  },
  "keywords": [
    "design-system",
    "brutalist",
    "lit",
    "web-components",
    "tailwind",
    "ui"
  ],
  "author": "Syntesa",
  "license": "MIT",
  "packageManager": "pnpm@10.19.0",
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@cspell/dict-html": "^4.0.14",
    "@cspell/dict-typescript": "^3.2.3",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@storybook/web-components": "^10.2.8",
    "@storybook/web-components-vite": "^10.2.8",
    "@types/react": "^19.2.13",
    "autoprefixer": "^10.4.24",
    "cspell": "^9.6.4",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "storybook": "^10.2.8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "peerDependencies": {
    "@lit/react": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@lit/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}

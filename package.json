{
  "name": "@wearesyntesa/karbit-ui",
  "version": "0.1.0",
  "description": "Brutalist design system built on Lit with Chakra UI-like API and Tailwind CSS",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/core/theme.d.ts",
      "import": "./dist/core/theme.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./*": null
  },
  "sideEffects": [
    "./dist/components/**/*.js",
    "./dist/react/**/*.js"
  ],
  "customElements": "custom-elements.json",
  "files": [
    "dist",
    "tailwind.config.ts",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "cem": "cem analyze",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "design-system",
    "brutalist",
    "lit",
    "web-components",
    "tailwind",
    "ui"
  ],
  "author": "Syntesa",
  "license": "MIT",
  "packageManager": "pnpm@10.19.0",
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@storybook/web-components": "^10.2.8",
    "@storybook/web-components-vite": "^10.2.8",
    "@types/react": "^19.2.13",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "storybook": "^10.2.8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "peerDependencies": {
    "@lit/react": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@lit/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}

  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build && vite build --config vite.config.css.ts && node --input-type=module -e \"import { readFile } from 'node:fs/promises'; const defineEntry = await readFile(new URL('./dist/define.js', import.meta.url), 'utf8'); if (!defineEntry.includes('define(\\\"kb-input\\\"') || !defineEntry.includes('karbitElementsDefined')) { throw new Error('dist/define.js does not contain the expected Karbit custom-element registrations.'); }\"",
    "typecheck": "tsc --noEmit",
    "cem": "cem analyze",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "knip": "knip",
    "spellcheck": "cspell \"src/**/*.ts\"",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "docs": "pnpm --filter @wearesyntesa/karbit-ui-docs start",
    "docs:build": "pnpm --filter @wearesyntesa/karbit-ui-docs build",
    "docs:serve": "pnpm --filter @wearesyntesa/karbit-ui-docs serve",
    "example:react": "pnpm --filter @wearesyntesa/karbit-ui-react-sample dev",
    "example:vue": "pnpm --filter @wearesyntesa/karbit-ui-vue-sample dev",
    "example:svelte": "pnpm --filter @wearesyntesa/karbit-ui-svelte-sample dev",
    "docs:deploy": "pnpm build && pnpm docs:build && wrangler pages deploy docs/build --project-name karbitui-docs --branch main",
    "docs:deploy:preview": "pnpm build && pnpm docs:build && wrangler pages deploy docs/build --branch preview"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  },
